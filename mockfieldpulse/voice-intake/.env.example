# Copy this file to .env and fill in real values. .env is gitignored.

# Anthropic API key for the extractor (Claude).
ANTHROPIC_API_KEY=sk-ant-...

# Mock FieldPulse connection (defaults shown).
FIELDPULSE_BASE_URL=http://localhost:5000
FIELDPULSE_API_KEY=dev-test-key-12345

# Auth key the orchestrator requires on the x-intake-key header.
INTAKE_API_KEY=dev-intake-key

# Cloudflare R2 (S3-compatible) for consultation audio storage. Get these
# from Cloudflare dashboard → R2 → Manage R2 API Tokens. The endpoint URL
# uses your account id, NOT the bucket name.
R2_ENDPOINT_URL=https://abc123def456.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=threeday-consultations

# Redis (for the async consultation queue via RQ). Defaults to local
# Homebrew Redis; on Render use the Redis add-on's connection URL.
REDIS_URL=redis://localhost:6379
