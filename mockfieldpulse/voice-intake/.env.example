# Copy this file to .env and fill in real values. .env is gitignored.

# Anthropic API key for the extractor (Claude).
ANTHROPIC_API_KEY=sk-ant-...

# Mock FieldPulse connection (defaults shown).
FIELDPULSE_BASE_URL=http://localhost:5000
FIELDPULSE_API_KEY=dev-test-key-12345

# Auth key the orchestrator requires on the x-intake-key header.
INTAKE_API_KEY=dev-intake-key
